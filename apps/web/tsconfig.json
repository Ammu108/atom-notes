{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"jsx": "preserve",
		"plugins": [{ "name": "next" }],
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"],
			"@repo/db": ["../../packages/db/src/index.ts"],
			"@repo/api": ["../../packages/api/src/index.ts"],
			"@repo/api/verifyToken": ["../../packages/api/src/auth/utils/token.ts"],
			"@repo/ui": ["../../packages/ui/src/index.ts"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
